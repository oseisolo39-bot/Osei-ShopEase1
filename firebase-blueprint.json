{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Store product",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "rating": { "type": "number" },
        "reviews": { "type": "number" },
        "stock": { "type": "number" }
      },
      "required": ["name", "price", "description", "image", "category", "rating", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "shippingAddress": { "type": "object" }
      },
      "required": ["userId", "items", "total", "status", "createdAt", "shippingAddress"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/entities/User",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "#/entities/Product",
      "description": "Store products"
    },
    "/orders/{orderId}": {
      "schema": "#/entities/Order",
      "description": "Customer orders"
    }
  }
}
